datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

model User {
  id          String   @id @default(cuid())
  clerkUserId String   @unique
  email       String   @unique
  name        String?
  image       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  websites    Website[]
}

model Website {
  id          String   @id @default(cuid())
  userId      String
  name        String
  domain      String   @unique
  apiSecret   String   @unique
  status      String   @default("ACTIVE") // "ACTIVE" or "INACTIVE"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leads       Lead[]

  @@index([userId])
}

model Lead {
  id          String   @id @default(cuid())
  websiteId   String

  // ── Common typed fields (present on most forms) ──────────────────────────
  // These are indexed/queryable columns. Map inbound JSON keys to these where possible.
  name        String?
  email       String?
  phone       String?
  company     String?
  message     String?
  source      String?  // e.g. "contact-form", "newsletter", "demo-request"

  // ── Flexible catch-all for website-specific fields ────────────────────────
  // Any key sent by the website that doesn't map to a typed column above
  // is stored here. Schema is intentionally open — every website can differ.
  // Example: { "budget": "5000", "projectType": "web", "country": "US" }
  data        Json?

  // ── System / request metadata ─────────────────────────────────────────────
  ip          String?
  userAgent   String?
  referrer    String?

  submittedAt DateTime @default(now())
  createdAt   DateTime @default(now())

  // Relationships
  website     Website  @relation(fields: [websiteId], references: [id], onDelete: Cascade)

  @@index([websiteId])
  @@index([email])
}
